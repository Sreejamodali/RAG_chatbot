# Example environment variables for RAG Chatbot
# Copy this file to .env and fill in your values

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Database (if used)
DATABASE_URL=sqlite:///./mydb.sqlite

# OpenAI or other LLM API keys (if used)
OPENAI_API_KEY=

# Add any other required environment variables below
